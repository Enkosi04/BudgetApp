<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="#F8F9FB">
    <!--  Top App Bar  -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#1565C0" android:padding="14dp" android:gravity="center_vertical">
        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/menu" android:layout_marginEnd="12dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="BudgetBuddy" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:gravity="center"/>
        <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/budgeticon"/>
    </LinearLayout>
    <!--  Scrollable Content  -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <!--  Welcome Text  -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Welcome, SyntaxTerror" android:textSize="22sp" android:textStyle="bold" android:textColor="#1A1A1A" android:layout_marginBottom="16dp"/>
            <!--  Total Balance Card  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#1565C0" android:padding="24dp" android:gravity="center" android:layout_marginBottom="16dp" android:elevation="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Balance" android:textSize="16sp" android:textColor="#BBDEFB" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvTotalBalance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R87,500" android:textSize="36sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
            </LinearLayout>
            <!--  This Month's Budget Card  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="16dp" android:layout_marginBottom="16dp" android:elevation="2dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="This Month's Budget" android:textSize="15sp" android:textStyle="bold" android:textColor="#1A1A1A" android:layout_marginBottom="10dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/tvBudgetAmounts" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="R40,000 / R35,000" android:textSize="15sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
                    <TextView android:id="@+id/tvOverBudgetPercent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="114%" android:textSize="13sp" android:textColor="#FFFFFF" android:background="#1565C0" android:paddingHorizontal="10dp" android:paddingVertical="3dp"/>
                </LinearLayout>
                <!--  Over-budget progress bar (red tint if over 100%)  -->
                <ProgressBar android:id="@+id/progressBudgetMain" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="12dp" android:progress="100" android:progressTint="#1565C0" android:progressBackgroundTint="#E0E0E0"/>
            </LinearLayout>
            <!--  Recent Transactions Card  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="16dp" android:elevation="2dp">
                <!--  Header Row  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Recent Transactions" android:textSize="15sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• • •" android:textSize="16sp" android:textColor="#AAAAAA"/>
                </LinearLayout>
                <!--  Groceries Row  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/grocery" android:layout_marginEnd="14dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Groceries" android:textSize="15sp" android:textColor="#333333"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R840" android:textSize="15sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
                </LinearLayout>
                <!--  Dining Out Row  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/dinning" android:layout_marginEnd="14dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dining Out" android:textSize="15sp" android:textColor="#333333"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R560" android:textSize="15sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
                </LinearLayout>
                <!--  Transport Row  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/transport" android:layout_marginEnd="14dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Transport" android:textSize="15sp" android:textColor="#333333"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R280" android:textSize="15sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <!--  Bottom Navigation Bar  -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#FFFFFF" android:padding="10dp" android:elevation="8dp">
        <LinearLayout android:id="@+id/navAddExpense" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="horizontal" android:gravity="center" android:padding="8dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/expense" android:layout_marginEnd="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add Expense" android:textSize="12sp" android:textColor="#1565C0"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navViewReports" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="horizontal" android:gravity="center" android:padding="8dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/viewreport" android:layout_marginEnd="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View Reports" android:textSize="12sp" android:textColor="#1565C0"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navSetGoal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="horizontal" android:gravity="center" android:padding="8dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/goal" android:layout_marginEnd="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Set Goal" android:textSize="12sp" android:textColor="#1565C0"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>